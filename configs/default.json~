{
  "model": {
    "dim": 512,
    "n_q": 16,
    "card": 2048,
    "num_heads": 8,
    "num_layers": 6,
    "dec_num_layers": 6,
    "num_speaker_latents": 16,
    "num_prosody_latents": 32,
    "num_prosody_tokens": 32,
    "hidden_scale": 4.0,
    "text_encoder_layers": 6,
    "jepa_layers": 4,
    "jepa_heads": 8,
    "depformer_num_layers": 6,
    "num_codebooks": 16,
    "use_pre_norm": true,
    "use_contrastive_duration": true,
    "use_speaker": true,
    "use_prosody": true,
    "use_jepa_planner": true,
    "use_phonetic": true,
    "bpe_encoder": {
      "enabled": true,
      "bpe_layers": 2,
      "use_pretrained_embeddings": true,
      "freeze_bpe_embeddings": false,
      "combination": "add"
    }
  },
  "training": {
    "batch_size": 16,
    "num_workers": 8,
    "lr": 1e-5,
    "warmup_steps": 2000,
    "epochs": 100,
    "train_tokens_path": [
      "../autovoc/dataset/hifitts/train_tokens_hifitts.pt"
    ],
    "output_prefix": "seedvox_",
    "jepa_weight": 2.0,
    "ph_weight": 0.1,
    "dur_weight": 0.05,
    "val_ratio": 0.02,
    "ema_decay": 0.999
  }
}
